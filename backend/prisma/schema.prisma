generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  HIRED
}

enum MatchStatus {
  PENDING
  REVIEWED
  ACCEPTED
  DECLINED
}

// ─────────────────────────────────────────────
// 1. USERS
// ─────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  role            Role      @default(STUDENT)
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  studentProfile    StudentProfile?
  recruiterProfile  RecruiterProfile?
  chatbotSessions   ChatbotSession[]
  notifications     Notification[]
}

// ─────────────────────────────────────────────
// 2. STUDENT PROFILES
// ─────────────────────────────────────────────

model StudentProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  fullName        String
  bio             String?
  college         String?
  degree          String?
  branch          String?
  graduationYear  Int?
  cgpa            Float?
  location        String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  resumeText      String?   // Extracted / typed resume text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentSkills   StudentSkill[]
  applications    Application[]
  matchScores     MatchScore[]
  embeddingCache  EmbeddingCache?
}

// ─────────────────────────────────────────────
// 3. RECRUITER PROFILES
// ─────────────────────────────────────────────

model RecruiterProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  fullName        String
  companyName     String
  companyWebsite  String?
  industry        String?
  companySize     String?
  location        String?
  bio             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs            Job[]
}

// ─────────────────────────────────────────────
// 4. SKILLS (Master List)
// ─────────────────────────────────────────────

model Skill {
  id              String    @id @default(uuid())
  name            String    @unique  // e.g. "Python", "React", "Machine Learning"
  category        String?           // e.g. "Programming", "Soft Skills", "Tools"
  createdAt       DateTime  @default(now())

  // Relations
  studentSkills   StudentSkill[]
  jobSkills       JobSkill[]
}

// ─────────────────────────────────────────────
// 5. STUDENT SKILLS (Many-to-Many)
// ─────────────────────────────────────────────

model StudentSkill {
  id              String    @id @default(uuid())
  studentId       String
  skillId         String
  proficiency     String?   // "Beginner" | "Intermediate" | "Expert"
  yearsExp        Float?

  // Relations
  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill           Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([studentId, skillId])
}

// ─────────────────────────────────────────────
// 6. JOBS
// ─────────────────────────────────────────────

model Job {
  id              String    @id @default(uuid())
  recruiterId     String
  title           String
  description     String
  location        String?
  jobType         String?   // "Internship" | "Full-time" | "Part-time"
  stipend         Float?
  minCgpa         Float?
  eligibleBranches String[] // e.g. ["CSE", "IT", "ECE"]
  openings        Int       @default(1)
  deadline        DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  recruiter       RecruiterProfile  @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  jobSkills       JobSkill[]
  applications    Application[]
  matchScores     MatchScore[]
  embeddingCache  EmbeddingCache?
}

// ─────────────────────────────────────────────
// 7. JOB SKILLS (Many-to-Many)
// ─────────────────────────────────────────────

model JobSkill {
  id              String    @id @default(uuid())
  jobId           String
  skillId         String
  isRequired      Boolean   @default(true)  // Required vs Nice-to-have
  weightage       Float     @default(1.0)   // Used in rule-based scoring

  // Relations
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill           Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
}

// ─────────────────────────────────────────────
// 8. MATCH SCORES
// ─────────────────────────────────────────────

model MatchScore {
  id              String      @id @default(uuid())
  studentId       String
  jobId           String
  similarityScore Float       // SBERT cosine similarity (0–1)
  ruleScore       Float       // Rule-based score (0–1)
  finalScore      Float       // 0.7 * similarity + 0.3 * rule
  rank            Int?        // Rank among all candidates for this job
  shapValues      Json?       // SHAP explanation { skill: contribution, ... }
  explanation     String?     // Human-readable explanation string
  status          MatchStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
  @@index([jobId, finalScore(sort: Desc)])
}

// ─────────────────────────────────────────────
// 9. APPLICATIONS
// ─────────────────────────────────────────────

model Application {
  id              String            @id @default(uuid())
  studentId       String
  jobId           String
  status          ApplicationStatus @default(APPLIED)
  coverNote       String?
  appliedAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
}

// ─────────────────────────────────────────────
// 10. CHATBOT SESSIONS
// ─────────────────────────────────────────────

model ChatbotSession {
  id              String    @id @default(uuid())
  userId          String
  messages        Json      // Array of { role: "user"|"assistant", content: string }
  extractedData   Json?     // Structured JSON extracted by LLM from conversation
  isComplete      Boolean   @default(false)  // Profile fully collected?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// 11. NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id              String    @id @default(uuid())
  userId          String
  title           String
  message         String
  type            String    // "MATCH" | "APPLICATION" | "STATUS_UPDATE" | "SYSTEM"
  isRead          Boolean   @default(false)
  metadata        Json?     // Optional: { jobId, applicationId, matchId }
  createdAt       DateTime  @default(now())

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─────────────────────────────────────────────
// BONUS: EMBEDDINGS CACHE
// ─────────────────────────────────────────────

model EmbeddingCache {
  id              String    @id @default(uuid())
  studentId       String?   @unique
  jobId           String?   @unique
  embedding       Float[]   // SBERT vector (384 dims for all-MiniLM-L6-v2)
  inputHash       String    // MD5/SHA of input text — invalidate on change
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  student         StudentProfile?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job?             @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
