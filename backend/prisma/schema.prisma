generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  REJECTED
  HIRED
}

enum MatchStatus {
  PENDING
  REVIEWED
  ACCEPTED
  DECLINED
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ExperienceLevel {
  FRESHER
  INTERN
  JUNIOR
  MID
  SENIOR
}

// ── 1. USERS ───────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?   // ADDED: used by chatbot greeting
  passwordHash    String
  role            Role      @default(STUDENT)
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  studentProfile    StudentProfile?
  recruiterProfile  RecruiterProfile?
  chatbotSessions   ChatbotSession[]
  notifications     Notification[]
}

// ── 2. STUDENT PROFILES ────────────────────────────────────

model StudentProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  fullName             String
  bio                  String?
  college              String?
  degree               String?
  branch               String?
  graduationYear       Int?
  cgpa                 Float?
  location             String?
  linkedinUrl          String?
  githubUrl            String?
  portfolioUrl         String?
  resumeUrl            String?    // ADDED: Cloudinary URL
  resumePublic         Boolean   @default(true) // ADDED: visibility toggle
  resumeText           String?
  preferredRoles       String[]
  experienceLevel      String?
  preferredLocations   String[]
  socialLinks          String[]  // ADDED: extra social links
  certificationsPublic Boolean   @default(true) // ADDED: certs visibility
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentSkills   StudentSkill[]
  applications    Application[]
  matchScores     MatchScore[]
  embeddingCache  EmbeddingCache?
  certifications  Certification[]  // ADDED
}

// ── 2b. CERTIFICATIONS ─────────────────────────────────────

model Certification {
  id          String    @id @default(uuid())
  studentId   String
  name        String
  url         String    // Cloudinary URL
  publicId    String    // Cloudinary public_id
  uploadedAt  DateTime  @default(now())

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

// ── 3. RECRUITER PROFILES ──────────────────────────────────

model RecruiterProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  fullName        String
  companyName     String
  companyWebsite  String?
  industry        String?
  companySize     String?
  location        String?
  bio             String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs            Job[]
}

// ── 4. SKILLS ──────────────────────────────────────────────

model Skill {
  id              String    @id @default(uuid())
  name            String    @unique
  category        String?
  createdAt       DateTime  @default(now())

  studentSkills   StudentSkill[]
  jobSkills       JobSkill[]
}

// ── 5. STUDENT SKILLS ──────────────────────────────────────

model StudentSkill {
  id              String    @id @default(uuid())
  studentId       String
  skillId         String
  proficiency     String?
  yearsExp        Float?

  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill           Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([studentId, skillId])
}

// ── 6. JOBS ────────────────────────────────────────────────

model Job {
  id               String          @id @default(uuid())
  recruiterId      String
  title            String
  description      String
  location         String?
  jobType          JobType         @default(FULL_TIME)
  workMode         WorkMode        @default(ONSITE)
  experienceLevel  ExperienceLevel @default(FRESHER)
  education        String          @default("Any")
  salaryMin        Int?
  salaryMax        Int?
  duration         String?
  openings         Int             @default(1)
  perks            String[]
  aboutCompany     String?
  minCgpa          Float?
  eligibleBranches String[]
  deadline         DateTime?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  recruiter        RecruiterProfile  @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  jobSkills        JobSkill[]
  applications     Application[]
  matchScores      MatchScore[]
  embeddingCache   EmbeddingCache?
}

// ── 7. JOB SKILLS ──────────────────────────────────────────

model JobSkill {
  id              String    @id @default(uuid())
  jobId           String
  skillId         String
  isRequired      Boolean   @default(true)
  weightage       Float     @default(1.0)

  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill           Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
}

// ── 8. MATCH SCORES ────────────────────────────────────────

model MatchScore {
  id              String      @id @default(uuid())
  studentId       String
  jobId           String
  similarityScore Float
  ruleScore       Float
  finalScore      Float
  rank            Int?
  shapValues      Json?
  explanation     String?
  status          MatchStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
  @@index([jobId, finalScore(sort: Desc)])
}

// ── 9. APPLICATIONS ────────────────────────────────────────

model Application {
  id              String            @id @default(uuid())
  studentId       String
  jobId           String
  status          ApplicationStatus @default(APPLIED)
  coverNote       String?
  appliedAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  student         StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([studentId, jobId])
}

// ── 10. CHATBOT SESSIONS ───────────────────────────────────

model ChatbotSession {
  id              String    @id @default(uuid())
  userId          String
  messages        Json
  extractedData   Json?
  isComplete      Boolean   @default(false)
  onboardingStep  String    @default("GREETING")
  mode            String    @default("ONBOARDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages    ChatMessage[]
}

// ── 10b. CHAT MESSAGES ─────────────────────────────────────

model ChatMessage {
  id              String    @id @default(uuid())
  sessionId       String
  role            String
  content         String
  intent          String?
  metadata        Json?
  createdAt       DateTime  @default(now())

  session         ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ── 11. NOTIFICATIONS ──────────────────────────────────────

model Notification {
  id              String    @id @default(uuid())
  userId          String
  title           String
  message         String
  type            String
  isRead          Boolean   @default(false)
  metadata        Json?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ── 12. EMBEDDINGS CACHE ───────────────────────────────────

model EmbeddingCache {
  id              String    @id @default(uuid())
  studentId       String?   @unique
  jobId           String?   @unique
  embedding       Float[]
  inputHash       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student         StudentProfile?  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  job             Job?             @relation(fields: [jobId], references: [id], onDelete: Cascade)
}